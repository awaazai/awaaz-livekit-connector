# LiveKit project (Cloud or self-hosted)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Optional: explicit agent dispatch. Leave empty if your agent auto-dispatches
# (i.e. joins every room it is registered to).
LIVEKIT_AGENT_NAME=

# Where this connector listens for the Awaaz WebSocket.
CONNECTOR_HOST=0.0.0.0
CONNECTOR_PORT=8080

LOG_LEVEL=INFO
